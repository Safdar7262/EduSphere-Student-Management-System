# Copy this file to .env and adjust if your backend runs elsewhere.
# In development this isn't strictly needed because vite.config.js
# already proxies /api/* to http://localhost:8080.
#
# Only needed if you deploy frontend and backend separately (e.g.
# frontend on Vercel/Netlify, backend on a different server):
# VITE_API_BASE_URL=https://your-backend-domain.com/api/students
